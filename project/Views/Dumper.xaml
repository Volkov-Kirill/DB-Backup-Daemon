<Window x:Class="project.Views.Dumper"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:project.Views"
        mc:Ignorable="d"
        Title="Dumper" Height="300" Width="400">
    <Grid>
        <StackPanel Margin="10">
            <Button Name="btnSelectFolder" Content="Выбрать папку" Click="btnSelectFolder_Click" />
            <TextBox Name="txtFolderPath" IsReadOnly="True" Margin="0,5,0,10" />

            <Button Name="btnArchive" Content="Создать архив" Click="btnArchive_Click" />
        </StackPanel>
    </Grid>
</Window>
